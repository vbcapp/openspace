      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [
        -80,
        32
      ],
      "id": "b2c3d4e5-llm-chain",
      "name": "Basic LLM Chain1"
    },
    {
      "parameters": {
        "jsCode": "const text = $('Basic LLM Chain1').item.json.text;\n\nconst parts = [\n  { text: \"請根據以下文案生成一張示意圖：\" + text }\n];\n\nfor (let i = 0; i < items.length; i++) {\n  const binaryKey = Object.keys(items[i].binary)[0];\n  const binaryData = await this.helpers.getBinaryDataBuffer(i, binaryKey);\n  parts.push({\n    inline_data: {\n      mime_type: items[i].binary[binaryKey].mimeType,\n      data: binaryData.toString('base64')\n    }\n  });\n}\n\nconst body = {\n  contents: [{\n    role: \"user\",\n    parts\n  }],\n  systemInstruction: {\n    parts: [{\n      text: \"你生成的圖片必須嚴格遵守參考圖片的風格：暖色調的木質質感、生活感的構圖、以及自然的柔和光影。不要生成太像廣告的高對比圖，要像是一位朋友隨手拍下的美好瞬間。\"\n    }]\n  },\n  generationConfig: {\n    responseModalities: [\"IMAGE\"],\n    imageConfig: {\n      aspectRatio: \"9:16\",\n      imageSize: \"1K\"\n    }\n  }\n};\n\nconst response = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-image-preview:generateContent?key=AIzaSyAIeX6l753_VdDjq_mWfxQLl9PmiGvLnhc',\n  body,\n  json: true,\n  timeout: 120000,\n});\n\nconst imageData = response.candidates[0].content.parts[0].inlineData;\nconst buffer = Buffer.from(imageData.data, 'base64');\n\nreturn [{\n  json: { success: true },\n  binary: {\n    image: await this.helpers.prepareBinaryData(buffer, 'generated.png', imageData.mimeType)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
